{
  "name": "@intentcanvas/runtime",
  "version": "0.3.0",
  "description": "Local-only IntentCanvas review runtime and approval gateway.",
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/server.js",
    "./review-store": "./src/review-store.js"
  },
  "bin": {
    "intentcanvas-runtime": "./src/index.js"
  },
  "scripts": {
    "dev": "node ./src/index.js",
    "start": "node ./src/index.js",
    "test": "node --test"
  },
  "dependencies": {
    "@intentcanvas/local-auth": "workspace:*",
    "@intentcanvas/plan-diff": "workspace:*",
    "@intentcanvas/protocol": "workspace:*"
  },
  "engines": {
    "node": ">=22"
  }
}
