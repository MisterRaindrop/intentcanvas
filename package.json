{
  "name": "intentcanvas",
  "version": "0.1.0",
  "private": true,
  "description": "Visual-first planning, review, execution, and verification for AI-assisted code changes.",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @intentcanvas/runtime dev",
    "start": "pnpm --filter @intentcanvas/runtime start",
    "test": "pnpm -r test",
    "check:boundaries": "node tooling/check-boundaries.mjs",
    "check": "pnpm check:boundaries && pnpm test"
  }
}
