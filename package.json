{
  "name": "intentcanvas",
  "version": "0.3.0",
  "private": true,
  "description": "Visual-first planning, review, execution, and verification for AI-assisted code changes.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "intentcanvas": "./intentcanvas"
  },
  "scripts": {
    "setup": "node ./intentcanvas setup",
    "doctor": "node ./intentcanvas doctor",
    "dev": "pnpm --filter @intentcanvas/runtime dev",
    "start": "pnpm --filter @intentcanvas/runtime start",
    "intentcanvas": "node apps/cli/src/index.js",
    "facts": "node packages/code-facts/bin/code-facts.js",
    "diff": "node packages/plan-diff/src/bin.js",
    "facts-diff": "node packages/plan-diff/src/facts-bin.js",
    "bridge": "node packages/bridge/bin/intentcanvas-bridge.js",
    "test": "pnpm -r test && pnpm test:workflow",
    "test:workflow": "node --test tests/*.test.js scripts/*.test.mjs",
    "check:boundaries": "node tooling/check-boundaries.mjs",
    "check": "pnpm check:boundaries && pnpm test"
  }
}
